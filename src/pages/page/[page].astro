---
import BaseHead from "../../components/BaseHead.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LeftNav from "../../components/LeftNav.astro";
import PostCard from "../../components/PostCard.astro";
import PostPagination from "../../components/PostPagination.astro";
import RecentUpdate from "../../components/RecentUpdate.astro";
import { SITE_TITLE, POSTS_PER_PAGE } from "../../consts";
import { getSortedPosts, paginatePosts } from "../../utils/post";

export async function getStaticPaths() {
	const posts = await getSortedPosts(true);
	const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));

	return Array.from({ length: totalPages }, (_, currentPage) => ({
		params: { page: String(currentPage + 1) },
		props: {
			currentPage: currentPage + 1,
		},
	}));
}

const { currentPage } = Astro.props as {
	currentPage: number;
};

const posts = await getSortedPosts(true);
const { pagePosts, totalPages } = paginatePosts(posts, currentPage);
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead
			title={currentPage === 1 ? SITE_TITLE : `${SITE_TITLE} - 第 ${currentPage} 页`}
			description={`蔽夏的个人博客·文章目录第 ${currentPage} 页`}
		/>
	</head>
	<body>
		<BaseLayout>
			<LeftNav slot="left" />
			<h1 class="sr-only">最新文章</h1>
			<section class="posts-page">
				{
					pagePosts.map((post) => (
						<PostCard postid={post.id} />
					))
				}
				<PostPagination currentPage={currentPage} totalPages={totalPages} />
			</section>
			<style>
				.posts-page {
					list-style: none;
					padding: 1em 0;
					display: flex;
					flex-direction: column;
					gap: 1em;
					width: 100%;
					box-sizing: border-box;
					justify-content: start;
					min-height: 99vh;
				}
				/* 和 BaseLayout 的保持一致 */
				@media screen and (max-width: 800px) {
					.posts-page {
						padding: 0.8em 1em;
					}
				}
			</style>
			<RecentUpdate slot="right" collections={["posts"]} latestN={5} />
		</BaseLayout>
	</body>
</html>