---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";
import KatexStyle from "../components/KatexStyle.astro";
import Giscus from "../components/Giscus.astro";
import BaseLayout from "./BaseLayout.astro";
import StaticTOC from "../components/StaticTOC.astro";
import PrevNextPost from "../components/PrevNextPost.astro";
import Bibliography from "../components/Bibliography.astro";
import type { MarkdownHeading } from "astro";
import { type Post } from "../utils/post";
import type { BibliographyReference } from "../utils/bibliography";

type Props = Post["data"] & {
	headings: MarkdownHeading[];
	nextPost?: Post;
	prevPost?: Post;
	references?: BibliographyReference[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	headings,
	nextPost,
	prevPost,
	references = [],
} = Astro.props as Props;
---

<html lang="zh">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				view-transition-name: hero-img;
				box-shadow: 0px 4px 15px rgba(var(--gray), 0.5);
			}
			.prose {
				padding: 0 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			article {
				padding: 1em 0 0 0;
			}
			.content {
				--highlight-bg: rgba(221, 0, 255, 0.1);
				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					margin-left: -0.2em;
					padding-left: 0.2em;
					background: linear-gradient(
						to bottom,
						transparent 0%,
						transparent calc(100% - 0.6em),
						var(--highlight-bg) calc(100% - 0.6em),
						var(--highlight-bg) calc(100% - 0.1em),
						transparent calc(100% - 0.1em),
						transparent 100%
					);

					/* 多行每行独立渲染 */
					box-decoration-break: clone;
					-webkit-box-decoration-break: clone;
					display: inline;

					/* 模拟block行为 否则不会换行 */
					&::after {
						content: "";
						display: block;
						height: 0;
					}
				}
			}
			:global(.dark) .content {
				--highlight-bg: rgba(221, 0, 255, 0.3);
			}
			/* 和 BaseLayout 的保持一致 */
			@media screen and (max-width: 800px) {
				article {
					padding-top: 0;
				}
				.hero-image img {
					border-radius: 0;
				}
			}
		</style>
	</head>

	<body>
		<BaseLayout>
			<article data-pagefind-body>
				<div class="hero-image">
					{
						heroImage && (
							<Image
								width={800}
								src={heroImage}
								alt="hero image"
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<div class="content">
						<KatexStyle>
							<slot />
						</KatexStyle>
						<Bibliography references={references} />
					</div>
				</div>
			</article>
			<PrevNextPost nextPost={nextPost} prevPost={prevPost} />
			<Giscus style="padding: 0 1em 2em 1em; box-sizing: border-box;" />
			{
				headings.length > 0 && (
					<StaticTOC slot="right" headings={headings} />
				)
			}
		</BaseLayout>
	</body><script>
		// 图片点击放大功能
		function showImageOverlay(el: HTMLImageElement) {
			// 保存滚动条宽度以防止页面偏移
			const scrollbarWidth =
				window.innerWidth - document.documentElement.clientWidth;

			// 创建 overlay 背景
			const overlay = document.createElement("div");
			overlay.className = "overlay";
			overlay.style.cssText = [
				"position:fixed",
				"inset:0",
				"background:rgba(0,0,0,0)", // 初始透明度为0
				"z-index:2147483647",
				"cursor:zoom-out",
				"transition:background 300ms ease-out", // 添加背景过渡动画
			].join(";");

			// 克隆一个图片用于动画（fixed 定位）
			const clone = document.createElement("img");
			clone.src = el.src;
			clone.style.boxShadow = "0 8px 30px rgba(0,0,0,0.6)";
			clone.style.position = "fixed";
			clone.style.transition = "all 300ms cubic-bezier(.2,.8,.2,1)";
			clone.style.willChange = "transform, left, top, width, height";
			clone.style.cursor = "zoom-out";

			// 计算原图在视窗的位置与尺寸
			const rect = el.getBoundingClientRect();
			// left/top 使用视口坐标
			clone.style.left = `${rect.left}px`;
			clone.style.top = `${rect.top}px`;
			clone.style.width = `${rect.width}px`;
			clone.style.height = `${rect.height}px`;

			// 为了保留原始位置的占位效果，隐藏原图但保留占位
			const prevVisibility = el.style.visibility;
			el.style.visibility = "hidden";

			// 把 clone 和 overlay 添加入 DOM
			overlay.appendChild(clone);
			document.body.appendChild(overlay);

			// 保存滚动条状态并添加右侧padding防止页面偏移
			const prevBodyOverflow = document.body.style.overflow;
			const prevBodyPaddingRight = document.body.style.paddingRight;
			document.body.style.overflow = "hidden";
			if (scrollbarWidth > 0) {
				document.body.style.paddingRight = `${scrollbarWidth}px`;
			}

			// 触发遮罩透明度动画
			requestAnimationFrame(() => {
				overlay.style.background = "rgba(0,0,0,0.65)";
			});

			interface TargetSize {
				left: number;
				top: number;
				width: number;
				height: number;
			}
			// 触发到中间放大的目标尺寸：最大 95% 的视窗，同时保持图片纵横比
			function computeTarget(): Promise<TargetSize> {
				const vpW = window.innerWidth;
				const vpH = window.innerHeight;
				const maxW = vpW * 0.95;
				const maxH = vpH * 0.95;
				// 创建临时图片来获取固有比率
				const img = new Image();
				img.src = clone.src;
				return new Promise((resolve) => {
					img.onload = () => {
						const ratio = img.naturalWidth / img.naturalHeight;
						let targetW = img.naturalWidth;
						let targetH = img.naturalHeight;
						// 缩放到 maxW/maxH 中的最大适配
						if (targetW > maxW) {
							targetW = maxW;
							targetH = targetW / ratio;
						}
						if (targetH > maxH) {
							targetH = maxH;
							targetW = targetH * ratio;
						}
						const left = (vpW - targetW) / 2;
						const top = (vpH - targetH) / 2;
						resolve({ left, top, width: targetW, height: targetH });
					};
					if (img.complete) img.onload(new Event('load')); // 如果图片已经缓存
				});
			}

			// 开始动画到居中
			function applyTarget(t: TargetSize) {
				// 强制重绘以确保 transition 生效
				clone.getBoundingClientRect();
				requestAnimationFrame(() => {
					clone.style.left = `${t.left}px`;
					clone.style.top = `${t.top}px`;
					clone.style.width = `${t.width}px`;
					clone.style.height = `${t.height}px`;
				});
			}

			computeTarget().then((t) => {
				applyTarget(t);
			});

			// 在窗口尺寸改变时，重新计算目标位置/尺寸并应用（仅在放大状态）
			function onResize() {
				if (!isZoomed) return;
				computeTarget().then((t) => {
					applyTarget(t);
				});
			}
			window.addEventListener("resize", onResize);

			let isZoomed = true;

			// 关闭（反向动画回到原位，然后清理）
			function close() {
				if (!isZoomed) return;
				isZoomed = false;

				// 遮罩透明度动画消失
				overlay.style.background = "rgba(0,0,0,0)";

				// 动画回原位置/尺寸
				clone.style.left = `${rect.left}px`;
				clone.style.top = `${rect.top}px`;
				clone.style.width = `${rect.width}px`;
				clone.style.height = `${rect.height}px`;

				// 等待 transitionend 清理 DOM
				const onEnd = (e: TransitionEvent) => {
					// 只处理 clone 的 transitionend
					if (e.target !== clone) return;
					clone.removeEventListener("transitionend", onEnd);
					el.style.visibility = prevVisibility || "";
					document.body.style.overflow = prevBodyOverflow || "";
					document.body.style.paddingRight =
						prevBodyPaddingRight || "";
					if (overlay.parentNode)
						overlay.parentNode.removeChild(overlay);
					window.removeEventListener("resize", onResize);
					document.removeEventListener("keydown", onKey);
				};
				clone.addEventListener("transitionend", onEnd);
			}

			// 点击 clone 或 overlay 关闭
			overlay.addEventListener("pointerup", (_) => close());
			function onKey(ev: KeyboardEvent) {
				if (ev.key === "Escape") close();
			}
			document.addEventListener("keydown", onKey);
		}
		window.addEventListener("load", () => {
			const content = document.querySelector(".prose .content");
			content?.querySelectorAll("img").forEach((img) => {
				img.style.cursor = "zoom-in";
				img.addEventListener("click", () => {
					showImageOverlay(img);
				});
			});
		});
	</script>
</html>
