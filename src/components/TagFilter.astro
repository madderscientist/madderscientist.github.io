---
import "../styles/toc.css";

interface Props {
    tags: string[];
    title?: string;
    style?: string;
}

const { tags, title = "标签聚合", style = "max-height:100%;height: fit-content;" } = Astro.props;
---

<nav
    class="toc-wrapper tag-filter-wrapper"
    aria-label={title}
    style={style}
>
    <span class="toc-title">
        {title}
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
        >
            <g
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-width="1.6"
                ><path
                    d="M3 6a4 4 0 0 1 4-4h4.5a3 3 0 0 1 2.12.879l5.95 5.95a4 4 0 0 1 0 5.656l-3.536 3.536a4 4 0 0 1-5.657 0L4.426 12.07A3.001 3.001 0 0 1 3 10.122V7Z"
                ></path><circle cx="8" cy="7" r="2" fill="currentColor"
                ></circle></g
            >
        </svg>
    </span>

    <div
        class="toc-content toc-scroll-container"
        style="padding-top: 0.5em !important; gap: 0.2em;"
    >
        {
            tags &&
                tags.length > 0 &&
                tags.map((tag) => (
                    <div
                        class="toc-item tag-filter-item"
                        data-tag={tag}
                        style="cursor: pointer;"
                    >
                        <div class="toc-label toc-label-primary">{tag}</div>
                    </div>
                ))
        }
    </div>
</nav>

<script>
    function updateTagsFilter() {
        const urlObj = new URL(window.location.href);
        const searchParams = urlObj.searchParams;
        const tagsParam = searchParams.get("tags");
        let activeTags = tagsParam ? tagsParam.split(",") : [];

        document.querySelectorAll(".tag-filter-item").forEach((elem) => {
            const tag = elem.getAttribute("data-tag");
            if (!tag) return;
            if (activeTags.includes(tag)) {
                (elem as HTMLElement).style.background =
                    "color-mix(in oklab, var(--primary) 15%, transparent)";
            } else {
                elem.classList.remove("visible");
                (elem as HTMLElement).style.background = "transparent";
            }
        });
    }

    document.querySelectorAll(".tag-filter-item").forEach((item) => {
        item.addEventListener("click", () => {
            const tag = item.getAttribute("data-tag");
            if (!tag) return;

            const urlObj = new URL(window.location.href);
            const tagsParam = urlObj.searchParams.get("tags");
            let activeTags = tagsParam ? tagsParam.split(",") : [];

            if (activeTags.includes(tag)) {
                activeTags = activeTags.filter((t) => t !== tag);
            } else {
                activeTags.push(tag);
            }

            if (activeTags.length > 0) {
                urlObj.searchParams.set("tags", activeTags.join(","));
            } else {
                urlObj.searchParams.delete("tags");
            }

            window.history.pushState({}, "", urlObj);
            updateTagsFilter();
            window.dispatchEvent(new Event("tags-updated"));
        });
    });

    updateTagsFilter();
    window.addEventListener("popstate", updateTagsFilter);
</script>

<style is:global>
    .tag-filter-wrapper {
        margin-top: 2em;
    }
    .tag-filter-wrapper .toc-content {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 0.3em !important;
    }
    .tag-filter-wrapper .tag-filter-item {
        width: auto;
        align-items: center;
        gap: 0.2em;
        padding: 0.1em 0.55em;
        border-radius: 999px;
        border: 1px solid color-mix(in oklab, var(--line-color) 72%, transparent);
    }
    .tag-filter-wrapper .tag-filter-item::before {
        content: "#";
        font-size: 0.7em;
        font-weight: bold;
        color: var(--primary);
    }
    .tag-filter-wrapper .tag-filter-item:hover {
        transform: translateY(-1.5px);
    }
    .tag-filter-wrapper .tag-filter-item .toc-label {
        max-width: none;
    }
</style>
