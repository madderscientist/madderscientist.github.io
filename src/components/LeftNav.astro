---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeIcon from "./ThemeIcon.astro";
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";

interface Props {
    title?: string;
    img?: string;
}

const { title = SITE_TITLE, img = "/favicon.svg" } = Astro.props;
---

<nav>
    <img src={img} alt="logo" width="128" height="128" />
    <div class="logos">
        <h2><a href="/" style="padding:0;">{title}</a></h2>
        <a href="/rss.xml" aria-label="RSS Feed">
            <svg
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
                ><path
                    d="M5 19a1 1 0 1 0 0-2a1 1 0 0 0 0 2Zm-1-8a9 9 0 0 1 9 9h2C15 14.477 9.523 9 3 9v2Zm0-7a16 16 0 0 1 16 16h2C22 10.059 13.941 2 4 2v2Z"
                    fill="currentColor"></path>
            </svg>
        </a>
    </div>
    <div class="search-container" data-pf-theme="light">
        <PagefindConfig
            instance="search"
            preload="false"
            highlight-param="highlight"
        />
        <!-- <pagefind-searchbox instance="search" show-sub-results="true"></pagefind-searchbox> -->
        <pagefind-modal-trigger instance="search" shortcut="/"
        ></pagefind-modal-trigger>
        <pagefind-modal instance="search"></pagefind-modal>
    </div>
