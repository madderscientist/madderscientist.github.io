    <ThemeIcon />
    <style>
        nav {
            box-sizing: border-box;
            padding: 2em 1em;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5em;
            height: 100%;
            position: relative;
            --bg-brightness: 1;
            --bg-blur: 100px;
            view-transition-name: left-nav;

            :global(a),
            :global(a.active) {
                text-decoration: none;
                color: var(--black);
            }
        }
        :global(.dark) nav {
            --bg-brightness: 0.3;
            --bg-blur: 80px;
            img {
                filter: brightness(150%);
            }
        }
        nav::after {
            z-index: -1;
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 80%;
            height: 80%;
            transform: translate(-50%, -50%);
            filter: saturate(400%) blur(var(--bg-blur)) opacity(0.6)
                brightness(var(--bg-brightness));
            background-size: cover;
            background-image: url(https://gcore.jsdelivr.net/gh/cdn-x/placeholder@1.0.13/image/sidebar-bg1@small.jpg);
        }
        .logos {
            display: flex;
            flex-wrap: nowrap;
            align-items: center;
            gap: 0.5em;
            h2 {
                margin: 0;
                font-size: 1.5em;
            }
        }
        .search-container {
            width: 100%;
            pagefind-modal-trigger {
                width: 100%;
            }
            .pf-trigger-btn {
                background: color-mix(
                    in srgb,
                    var(--pf-background) 60%,
                    transparent
                ) !important;
            }
        }
        .internal-links {
            display: flex;
            flex-direction: column;
            width: 100%;
            flex: 1;
            :global(a),
            :global(a.active) {
                border-radius: 0.5em;
                padding: 0.2em 0.6em 0.2em 1em;
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 0.5em;
                span {
                    flex-grow: 1;
                }
            }
            :global(a) {
                background-color: transparent;
            }
            :global(a.active) {
                background-color: var(--c-bg-soft);
                &::after {
                    content: "";
                    width: 0.3em;
                    height: 0.3em;
                    border-radius: 1em;
                    background-color: rgb(var(--gray-dark));
                }
            }
        }
    </style>
    <script>
        function setPagefindTheme(isDark: boolean) {
            const allElements = document.querySelectorAll("[data-pf-theme]");
            allElements.forEach((el) => {
                el.setAttribute("data-pf-theme", isDark ? "dark" : "light");
            });
        }
        setPagefindTheme(document.documentElement.classList.contains("dark"));
        document.addEventListener("theme-toggle", (event) => {
            const newTheme = (event as CustomEvent).detail.theme;
            setPagefindTheme(newTheme === "dark");
        });
    </script>
</nav>
