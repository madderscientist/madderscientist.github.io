---
import type { MarkdownHeading } from "astro";
import "../styles/toc.css";

interface Props {
	headings?: import('astro').MarkdownHeading[];
	maxLevel?: number;
	scrollOffset?: number;
	title?: string;
	id?: string;
	style?: string;
}

const {
	headings = [],
	maxLevel = 3,
	scrollOffset = 0,
	title = "文章目录",
	id = "static-toc",
	style = "max-height:75%;height:fit-content;",
} = Astro.props as Props;

const tocContentId = `${id}-content`;

const validHeadings: MarkdownHeading[] = headings.filter(
	(heading): heading is MarkdownHeading =>
		Boolean(heading.slug) && heading.depth > 0,
);
const minDepth = validHeadings.reduce(
	(minimum: number, heading: MarkdownHeading) =>
		Math.min(minimum, heading.depth),
	10,
);

type TocItem = {
	slug: string;
	text: string;
	level: number;
	isTopLevel: boolean;
	index: number | null;
};

let topLevelIndex = 1;
const tocItems: TocItem[] = validHeadings
	.filter((heading) => heading.depth < minDepth + maxLevel)
	.map((heading: MarkdownHeading) => {
		const depth = heading.depth;
		const text = heading.text ?? "";
		const slug = heading.slug;
		const level = Math.min(depth - minDepth, 2);
		const isTopLevel = depth === minDepth;
		const index = isTopLevel ? topLevelIndex++ : null;

		return {
			slug,
			text,
			level,
			isTopLevel,
			index,
		};
	});
---

<nav id={id} class="toc-wrapper" aria-label={title} style={style}>
	<span
		class="toc-title"
		onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
	>
		{title}
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			><!-- Icon from Solar by 480 Design - https://creativecommons.org/licenses/by/4.0/ -->
			<g
				fill="none"
				stroke="currentColor"
				stroke-linecap="round"
				stroke-width="1.5"
				><path stroke-linejoin="round" d="m9 15.5l3-3l3 3m-6-4l3-3l3 3"
				></path><path
					d="M7 3.338A9.95 9.95 0 0 1 12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12c0-1.821.487-3.53 1.338-5"
				></path></g
			></svg
		>
	</span>

	<div class="toc-content toc-scroll-container" id={tocContentId}>
		{
			tocItems.length > 0 &&
				tocItems.map((item) => (
					<a
						href={`#${item.slug}`}
						class={`toc-item toc-level-${item.level}`}
						data-heading-id={item.slug}
						aria-label={item.text}
						title={item.text}
					>
						<div
							class={`toc-badge ${item.isTopLevel ? "toc-badge-index" : "toc-badge-dot"}`}
						>
							{item.isTopLevel ? item.index : ""}
						</div>
						<div
							class={`toc-label ${item.level <= 1 ? "toc-label-primary" : "toc-label-secondary"}`}
						>
							{item.text}
						</div>
					</a>
				))
		}
		<div style="opacity: 0;" class="toc-active-indicator"></div>
	</div>
</nav>
<script is:inline define:vars={{ id, tocItems, scrollOffset, tocContentId }}>
	// init 中赋值
	let tocRoot = null;
	let headings = []; // 文章中的标题元素
	let tocContent = null; // TOC内容容器元素
	let observer = null;

	// 获取当前视口内的标题ID列表，优先返回完全在视口内的标题
	// 如果没有，比如段落很长，返回上面最近的标题
	const getVisibleHeadingIds = () => {
		const visibleHeadingIds = [];
		// 记录视口外距离最近的标题，避免没有标题在视口内时没有高亮
		let minDis = Number.POSITIVE_INFINITY;
		let minDisId = null;

		headings.forEach((heading) => {
			const rect = heading.getBoundingClientRect();
			const d2top = rect.bottom - scrollOffset; // >0可见
			const d2bottom = rect.top - window.innerHeight - scrollOffset + 3; // <0可见 加3是防止最底下的标题因为padding，字还没进入视口就高亮了
			if (d2top <= 0) {
				// 在视口上方
				if (-d2top < minDis) {
					minDis = -d2top;
					minDisId = heading.id;
				}
			} else if (d2bottom < 0) {
				// 在视口内
				visibleHeadingIds.push(heading.id);
			} // 在视口下方: 不管
		});

		// 没有标题在视口内时，选上面最近的一个
		if (visibleHeadingIds.length === 0 && headings.length) {
			if (minDisId) {
				visibleHeadingIds.push(minDisId);
			}
		}

		return visibleHeadingIds;
	};

	// 更新高亮指示器位置和大小
	const updateActiveIndicator = (activeItems) => {
		const indicator = tocRoot.querySelector(".toc-active-indicator");
		if (!indicator) return;

		if (!activeItems.length) {
			indicator.style.opacity = "0";
			return;
		}

		const firstActive = activeItems[0];
		const lastActive = activeItems[activeItems.length - 1];

		// 设置大小
		indicator.style.opacity = "1";
		indicator.style.top = `${firstActive.offsetTop}px`;
		indicator.style.height = `${lastActive.offsetTop + lastActive.offsetHeight - firstActive.offsetTop}px`;

		// 滚动以保持父容器中可见
		const tocContainer = tocContent.closest(".toc-scroll-container");
		if (!tocContainer) return;

		// 没有滚动条
		if (tocContainer.scrollHeight <= tocContainer.clientHeight + 1) return;

		const groupTop = firstActive.offsetTop;
		const groupBottom = lastActive.offsetTop + lastActive.offsetHeight;
		const desired =
			(groupTop + groupBottom - tocContainer.clientHeight) / 2;
		const maxScroll = Math.max(
			0,
			tocContainer.scrollHeight - tocContainer.clientHeight,
		);
		const targetScroll = Math.min(Math.max(desired, 0), maxScroll);

		if (Math.abs(tocContainer.scrollTop - targetScroll) < 2) return; // 已经很接近了
		tocContainer.scrollTo({ top: targetScroll, behavior: "smooth" });
	};

	// 从 visible headings 得到对应的目录项
	const updateActiveState = () => {
		const tocItemsElements = Array.from(
			tocRoot.querySelectorAll(".toc-item"),
		);
		if (!tocItemsElements.length) return;

		tocItemsElements.forEach((item) => item.classList.remove("visible"));

		const visibleHeadingIds = getVisibleHeadingIds();
		const activeItems = tocItemsElements.filter((item) => {
			const headingId = item.dataset.headingId;
			return headingId && visibleHeadingIds.includes(headingId);
		});

		activeItems.forEach((item) => item.classList.add("visible"));
		updateActiveIndicator(activeItems);
	};

	// 节流更新，避免频繁调用
	let rafId = null;
	const scheduleActiveStateUpdate = () => {
		if (rafId !== null) window.cancelAnimationFrame(rafId);
		rafId = window.requestAnimationFrame(() => {
			rafId = null;
			updateActiveState();
		});
	};

	const cleanup = () => {
		if (observer) {
			observer.disconnect();
			observer = null;
		}
		if (rafId !== null) {
			window.cancelAnimationFrame(rafId);
			rafId = null;
		}
	};

	const init = () => {
		cleanup();
		// 基本元素 只获取一次
		tocRoot = document.getElementById(id);
		tocContent = document.getElementById(tocContentId);
		if (!tocRoot || !tocContent) return;

		//== 目录点击 ==//
		const handleClick = (event) => {
			event.preventDefault(); // 拦截默认锚点跳转(不修改URL)
			const targetId = decodeURIComponent(
				event.currentTarget.getAttribute("href")?.substring(1) || "",
			);
			const targetElement = document.getElementById(targetId);
			if (targetElement) {
				const targetTop =
					targetElement.getBoundingClientRect().top +
					window.pageYOffset -
					scrollOffset;
				window.scrollTo({ top: targetTop, behavior: "smooth" });
			}
		};
		const tocLinks = Array.from(tocRoot.querySelectorAll(".toc-item"));
		tocLinks.forEach((link) => {
			link.removeEventListener("click", handleClick);
			link.addEventListener("click", handleClick);
		});

		// 监听
		headings = tocItems
			.map((item) => document.getElementById(item.slug))
			.filter((element) => element);
		observer = new IntersectionObserver(scheduleActiveStateUpdate, {
			root: null, // 使用 viewport 作为 root
			rootMargin: `${-scrollOffset}px 0px 0px 0px`,
			threshold: 0.1,
		});
		headings.forEach((heading) => observer.observe(heading));
		scheduleActiveStateUpdate();
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", init, { once: true });
	} else init();
	window.addEventListener("beforeunload", cleanup);
</script>
