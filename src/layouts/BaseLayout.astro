---
import Footer from "../components/Footer.astro";
import LeftNav from "../components/LeftNav.astro";
// 侧边sticky，都到底了显示 footer

// 设置最大栏数 默认为3，最小为2
export interface Props {
    columns?: number;
}

const { columns = 3 } = Astro.props;
const colCount = Math.max(2, columns);
---

<div class="blog-root">
    <aside class="l_left">
        <slot name="left">
            <LeftNav />
        </slot>
    </aside>
    <main>
        <slot />
    </main>
    <aside class="l_right">
        <slot name="right" />
    </aside>
</div>
<Footer />

<style>
    .blog-root {
        --gap-margin: 12px;
        display: grid;
        grid-template-columns: 1fr minmax(200px, var(--width-main)) 1fr;
        gap: calc(var(--gap-margin) * 3);
        min-height: 100vh;
        margin-bottom: calc(var(--gap-margin) * 4);
        --side-width: 288px;
        & > aside {
            align-self: start;
            position: sticky;
            top: 0;
            width: var(--side-width);
            z-index: 8;
            height: 100vh;
            transform: translateX(0);
            transition: transform 0.3s ease-out;
        }
        .l_left {
            justify-self: right;
        }
        .l_right {
            justify-self: left;
        }
    }
    @media screen and (max-width: 1440px) {
        .blog-root {
            gap: calc(var(--gap-margin) * 2);
        }
    }
    @media screen and (max-width: 1300px) {
        .blog-root {
            gap: calc(var(--gap-margin) * 1);
            grid-template-columns: 1fr minmax(200px, var(--width-main)) 0fr;
        }
        .blog-root > .l_right {
            position: fixed;
            transform: translateX(var(--side-width));
            right: 0;
            box-shadow: rgba(0, 0, 0, 0.2) 0px 12px 16px -4px;
            z-index: 10;
            overflow: auto;
        }
    }
    @media screen and (max-width: 1000px) {
        .blog-root {
            display: block;
        }
        .blog-root > .l_left {
            position: fixed;
            transform: translateX(calc(-1 * var(--side-width)));
            left: 0;
            box-shadow: rgba(0, 0, 0, 0.2) 0px 12px 16px -4px;
            z-index: 10;
        }
    }
</style>
