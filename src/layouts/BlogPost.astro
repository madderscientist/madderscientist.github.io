---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";
import KatexStyle from "../components/KatexStyle.astro";
import Giscus from "../components/Giscus.astro";
import BaseLayout from "./BaseLayout.astro";
import StaticTOC from "../components/StaticTOC.astro";
import PrevNextPost from "../components/PrevNextPost.astro";
import type { MarkdownHeading } from "astro";
import { type Post } from "../utils/post";

type Props = Post["data"] & {
	headings: MarkdownHeading[];
	nextPost?: Post;
	prevPost?: Post;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	headings,
	nextPost,
	prevPost,
} = Astro.props as Props;
---

<html lang="zh">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				view-transition-name: hero-img;
				box-shadow: 0px 4px 15px rgba(var(--gray), 0.5);
			}
			.prose {
				padding: 0 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			article {
				padding: 1em 0 0 0;
			}
			.content {
				h1,
				h2,
				h3,
				h4,
				h5,
				h6 {
					margin-left: -0.2em;
					padding-left: 0.2em;
					background: linear-gradient(
						to bottom,
						transparent 0%,
						transparent calc(100% - 0.6em),
						rgba(221, 0, 255, 0.1) calc(100% - 0.6em),
						rgba(221, 0, 255, 0.1) calc(100% - 0.1em),
						transparent calc(100% - 0.1em),
						transparent 100%
					);
					
					/* 多行每行独立渲染 */
					box-decoration-break: clone;
					-webkit-box-decoration-break: clone;
					display: inline;
				}
			}
			/* 和 BaseLayout 的保持一致 */
			@media screen and (max-width: 800px) {
				article {
					padding-top: 0;
				}
				.hero-image img {
					border-radius: 0;
				}
			}
		</style>
	</head>

	<body>
		<BaseLayout>
			<article data-pagefind-body>
				<div class="hero-image">
					{
						heroImage && (
							<Image
								width={800}
								src={heroImage}
								alt="hero image"
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<div class="content">
						<KatexStyle>
							<slot />
						</KatexStyle>
					</div>
				</div>
			</article>
			<PrevNextPost nextPost={nextPost} prevPost={prevPost} />
			<Giscus style="padding: 0 1em 2em 1em; box-sizing: border-box;" />
			{
				headings.length > 0 && (
					<StaticTOC slot="right" headings={headings} />
				)
			}
		</BaseLayout>
	</body>
</html>
